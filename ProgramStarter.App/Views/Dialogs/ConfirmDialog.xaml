<Window x:Class="ProgramStarter.App.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText, Mode=OneWay}"
        MinWidth="400" MaxWidth="500"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="{StaticResource DialogPadding}">
        <TextBlock Text="{Binding TitleText, Mode=OneWay}" Style="{StaticResource DialogTitleStyle}" />
        <TextBlock Text="{Binding Message, Mode=OneWay}" Style="{StaticResource DialogMessageStyle}" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource NeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,8,0" />
            <Button Content="{Binding ConfirmText, Mode=OneWay}"
                    Style="{StaticResource DangerButtonStyle}"
                    IsDefault="True"
                    Click="OnConfirmClick" />
        </StackPanel>
    </StackPanel>
</Window>
