<Window x:Class="ProgramStarter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProgramStarter.App.ViewModels"
        Title="Program Starter"
        MinWidth="900" MinHeight="560"
        Width="960" Height="640"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- Inverted BooleanToVisibilityConverter via style trigger -->
        <Style x:Key="VisibleWhenFalse" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasGroups, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hidden when HasSelectedGroup is true (inverted) -->
        <Style x:Key="HiddenWhenSelected" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedGroup, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- No-Groups Empty State -->
        <DataTemplate x:Key="NoGroupsEmptyState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,32,0,0">
                <TextBlock Text="No groups yet"
                           Style="{StaticResource EmptyStateTitleStyle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Create your first launch group and start organizing your apps."
                           Style="{StaticResource EmptyStateTextStyle}"
                           Margin="0,0,0,24" />
                <Button Content="+ Add Group"
                        Command="{Binding AddGroupCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- Empty Group DataTemplate -->
        <DataTemplate x:Key="EmptyGroupState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Margin="0,32,0,0">
                <TextBlock Text="No apps in this group yet"
                           Style="{StaticResource EmptyStateTitleStyle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Add your first app to start building this launch group."
                           Style="{StaticResource EmptyStateTextStyle}"
                           Margin="0,0,0,24" />
                <Button Content="+ Add App"
                        Command="{Binding AddAppCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>

        <!-- App Card Template -->
        <DataTemplate x:Key="AppCardTemplate" DataType="vm:AppEntryItemViewModel">
            <Border x:Name="AppCardBorder"
                    Margin="0,0,0,10"
                    Style="{StaticResource AppCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- App name -->
                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="{Binding Name, Mode=OneWay}"
                               Style="{StaticResource CardTitleStyle}"
                               TextTrimming="CharacterEllipsis" />

                    <!-- Invalid path text (visible when path is invalid) -->
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="Path not found — edit to fix"
                               Foreground="{StaticResource WarningBrush}"
                               VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPathValid, Mode=OneWay}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- App path -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                               Text="{Binding Path, Mode=OneWay}"
                               Style="{StaticResource PathTextStyle}"
                               Margin="0,2,0,10" />

                    <!-- Actions -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                                Orientation="Horizontal">
                        <Button Content="Start"
                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.LaunchAppCommand}"
                                CommandParameter="{Binding}"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Height" Value="30" />
                                    <Setter Property="Padding" Value="14,0" />
                                    <Setter Property="FontSize" Value="12" />
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.IsLaunching}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPathValid, Mode=OneWay}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Edit"
                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.EditAppCommand}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource NeutralButtonStyle}"
                                Margin="0,0,8,0" />
                        <Button Content="Remove"
                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.RemoveAppCommand}"
                                CommandParameter="{Binding}"
                                Style="{StaticResource DangerButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <TextBlock Grid.Row="0"
                           Text="Program Starter"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="16,0,16,4" />

                <!-- Sidebar subtitle -->
                <TextBlock Grid.Row="1"
                           Text="Launch groups"
                           Style="{StaticResource MutedTextStyle}"
                           Margin="16,0,16,20" />

                <!-- Group List -->
                <ListBox Grid.Row="2"
                         ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0,8,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="14"
                                               FontWeight="Normal"
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="4,0,0,0"
                                                Visibility="Collapsed">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=IsMouseOver}"
                                                                 Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <Button Content="✏"
                                                ToolTip="Rename"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.RenameGroupCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                FontSize="11" />
                                        <Button Content="✕"
                                                ToolTip="Delete"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.DeleteGroupCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Margin="2,0,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource DangerBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="10,8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Accent indicator (visible when selected) -->
                                                <Rectangle Grid.Column="0"
                                                           x:Name="AccentBar"
                                                           Width="3"
                                                           Fill="{StaticResource AccentBrush}"
                                                           RadiusX="1.5" RadiusY="1.5"
                                                           VerticalAlignment="Stretch"
                                                               HorizontalAlignment="Left"
                                                           Visibility="Collapsed" />

                                                <!-- Content -->
                                                <ContentPresenter Grid.Column="1" Margin="8,0,0,0" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource CardHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectedSurfaceBrush}" />
                                                <Setter TargetName="AccentBar" Property="Visibility" Value="Visible" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Add Group Button -->
                <Button Grid.Row="3"
                        Content="+ Add Group"
                        Command="{Binding AddGroupCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="34"
                        FontSize="12"
                        Margin="8,8,8,16" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="{StaticResource MainContentPaddingThickness}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- No-Groups Empty State (visible when HasGroups is false) -->
            <ContentControl Grid.Row="0" Grid.RowSpan="3"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NoGroupsEmptyState}"
                            Style="{StaticResource VisibleWhenFalse}" />

            <!-- Content shown when groups exist -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding HasGroups, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">

                <!-- When a group is selected: show group name, app count, and action buttons -->
                <StackPanel Visibility="{Binding HasSelectedGroup, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding SelectedGroup.Name, Mode=OneWay, FallbackValue='Select a group'}"
                                       Style="{StaticResource MainTitleStyle}" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource SecondaryTextStyle}">
                                <Run Text="{Binding SelectedGroupAppCount, Mode=OneWay}" />
                                <Run Text=" apps in this group" />
                            </TextBlock>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Content="Start Group"
                                Command="{Binding LaunchGroupCommand}"
                                VerticalAlignment="Top"
                                Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLaunching, Mode=OneWay}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasSelectedGroup, Mode=OneWay}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <Button Grid.Column="2"
                                Content="+ Add App"
                                Command="{Binding AddAppCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"
                                VerticalAlignment="Top" />
                    </Grid>
                </StackPanel>

                <!-- When groups exist but none is selected -->
                <Border Style="{StaticResource HiddenWhenSelected}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="0,80,0,0">
                        <TextBlock Text="Select a group to get started"
                                   Style="{StaticResource EmptyStateTitleStyle}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Choose a launch group from the sidebar to manage its apps."
                                   Style="{StaticResource EmptyStateTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- App List or Empty Group State -->
            <Grid Grid.Row="1" Margin="0,24,0,0">
                <!-- App list when group has apps -->
                <ItemsControl ItemsSource="{Binding SelectedGroupApps, Mode=OneWay}"
                              Visibility="{Binding HasSelectedGroup, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AppCardTemplate}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Empty group state when group has no apps -->
                <ContentControl Content="{Binding}"
                                ContentTemplate="{StaticResource EmptyGroupState}" />
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Height="{StaticResource StatusBarHeight}"
                    Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay, FallbackValue='Ready'}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           Margin="12,0" />
            </Border>
        </Grid>
    </Grid>
</Window>
