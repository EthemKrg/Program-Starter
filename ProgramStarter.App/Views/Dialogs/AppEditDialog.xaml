<Window x:Class="ProgramStarter.App.Views.Dialogs.AppEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="Edit App"
        MinWidth="580" MaxWidth="580"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="32">
        <!-- Top header row: icon tile + title + subtitle -->
        <Grid Margin="0,0,0,22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Width="48" Height="48"
                    CornerRadius="15"
                    Background="{StaticResource AccentSurfaceBrush}"
                    BorderBrush="{StaticResource AccentMutedBrush}"
                    BorderThickness="1"
                    VerticalAlignment="Center">
                <Image Source="/Assets/Kaldforge/kaldforge_icon_launch_tile.png"
                       Width="34" Height="34"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </Border>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Edit App"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <TextBlock Text="Update launcher name and executable path."
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" />
            </StackPanel>
        </Grid>

        <!-- Name field -->
        <TextBlock Text="Name"
                   Style="{StaticResource DialogFieldLabelStyle}" />
        <TextBox x:Name="NameTextBox"
                 Text="{Binding AppName, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,22"
                 KeyDown="OnNameKeyDown" />

        <!-- Path field -->
        <TextBlock Text="Path"
                   Style="{StaticResource DialogFieldLabelStyle}" />
        <Grid Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="PathTextBox"
                     Text="{Binding AppPath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DialogTextBoxStyle}"
                     IsReadOnly="False"
                     KeyDown="OnPathKeyDown" />
             <Button Grid.Column="1"
                     Style="{StaticResource NeutralButtonStyle}"
                     Margin="12,0,0,0"
                     Height="44"
                     MinWidth="108"
                     Padding="18,0"
                     FontSize="14"
                     Click="OnBrowseClick">
                 <StackPanel Orientation="Horizontal">
                     <TextBlock Text="&#xED25;"
                                FontFamily="Segoe MDL2 Assets"
                                FontSize="14"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0" />
                     <TextBlock Text="Browse" VerticalAlignment="Center" />
                 </StackPanel>
             </Button>
        </Grid>

        <!-- Bottom actions: Cancel + Save Changes, right-aligned, gap 12 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource DialogNeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,12,0" />
            <Button x:Name="OkButton"
                    Content="Save Changes"
                    Style="{StaticResource DialogPrimaryButtonStyle}"
                    IsDefault="True"
                    MinWidth="148"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
