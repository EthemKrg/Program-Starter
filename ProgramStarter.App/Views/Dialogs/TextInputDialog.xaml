<Window x:Class="ProgramStarter.App.Views.Dialogs.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="{Binding Title, Mode=OneWay}"
        MinWidth="420"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="32">
        <!-- Premium dialog title: 22px SemiBold -->
        <TextBlock Text="{Binding Title, Mode=OneWay}"
                   Style="{StaticResource DialogTitleStyle}" />

        <!-- Message -->
        <TextBlock Text="{Binding Message, Mode=OneWay}"
                   Style="{StaticResource DialogMessageStyle}" />

        <!-- Premium textbox -->
        <TextBox x:Name="InputTextBox"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,28"
                 KeyDown="OnInputKeyDown" />

        <!-- Bottom actions: Cancel + OK -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource DialogNeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,12,0" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource DialogPrimaryButtonStyle}"
                    IsDefault="True"
                    MinWidth="118"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
