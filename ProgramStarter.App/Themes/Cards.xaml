<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App Card Style -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- App Card Hover Style (applied via triggers in the card template) -->
    <Style x:Key="AppCardHoverStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardHoverBrush}" />
    </Style>

    <!-- App Card Invalid Path Style -->
    <Style x:Key="AppCardInvalidStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InvalidBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- Sidebar Item Style -->
    <Style x:Key="SidebarItemStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!-- Sidebar Item Selected Style -->
    <Style x:Key="SidebarItemSelectedStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource SelectedSurfaceBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

</ResourceDictionary>
