<Window x:Class="ProgramStarter.App.Views.Dialogs.AppEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="Edit App"
        MinWidth="480" MaxWidth="560"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="{StaticResource DialogPadding}">
        <TextBlock Text="Edit App" Style="{StaticResource DialogTitleStyle}" />

        <!-- Name -->
        <TextBlock Text="Name" Style="{StaticResource DialogFieldLabelStyle}" />
        <TextBox x:Name="NameTextBox"
                 Text="{Binding AppName, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,4"
                 KeyDown="OnNameKeyDown" />

        <!-- Path -->
        <TextBlock Text="Path" Style="{StaticResource DialogFieldLabelStyle}" Margin="0,12,0,4" />
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="PathTextBox"
                     Text="{Binding AppPath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DialogTextBoxStyle}"
                     IsReadOnly="False"
                     KeyDown="OnPathKeyDown" />
            <Button Grid.Column="1"
                    Content="Browse"
                    Style="{StaticResource NeutralButtonStyle}"
                    Margin="8,0,0,0"
                    Height="34"
                    Padding="12,0"
                    Click="OnBrowseClick" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource NeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,8,0" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
