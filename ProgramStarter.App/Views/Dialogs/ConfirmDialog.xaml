<Window x:Class="ProgramStarter.App.Views.Dialogs.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding TitleText, Mode=OneWay}"
        MinWidth="440"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="32">
        <!-- Premium dialog title: 22px SemiBold -->
        <TextBlock Text="{Binding TitleText, Mode=OneWay}"
                   Style="{StaticResource DialogTitleStyle}" />

        <!-- Message -->
        <TextBlock Text="{Binding Message, Mode=OneWay}"
                   Style="{StaticResource DialogMessageStyle}" />

        <!-- Bottom actions: Cancel + Confirm (danger style) -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource DialogNeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,12,0" />
            <Button Content="{Binding ConfirmText, Mode=OneWay}"
                    Style="{StaticResource DialogDangerButtonStyle}"
                    IsDefault="True"
                    Click="OnConfirmClick" />
        </StackPanel>
    </StackPanel>
</Window>
