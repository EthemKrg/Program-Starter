<Window x:Class="ProgramStarter.App.Views.Dialogs.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="{Binding Title}"
        MinWidth="400" MaxWidth="500"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="DialogMessageStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="{Binding Title}" Style="{StaticResource DialogTitleStyle}" />
        <TextBlock Text="{Binding Message}" Style="{StaticResource DialogMessageStyle}" />

        <TextBox x:Name="InputTextBox"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,20"
                 KeyDown="OnInputKeyDown" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource NeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,8,0" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsDefault="True"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
