<Window x:Class="ProgramStarter.App.Views.Dialogs.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="{Binding Title, Mode=OneWay}"
        MinWidth="400" MaxWidth="500"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <StackPanel Margin="{StaticResource DialogPadding}">
        <TextBlock Text="{Binding Title, Mode=OneWay}" Style="{StaticResource DialogTitleStyle}" />
        <TextBlock Text="{Binding Message, Mode=OneWay}" Style="{StaticResource DialogMessageStyle}" />

        <TextBox x:Name="InputTextBox"
                 Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,20"
                 KeyDown="OnInputKeyDown" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource NeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,8,0" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    IsDefault="True"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
