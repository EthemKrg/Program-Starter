<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Phase 5H — Asset-Driven Card System -->

    <!-- App Card Style: height 128min, padding 24, radius 18, border 1.5 -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="128" />
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.16"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="-1" />
                        <ColorAnimation Duration="0:0:0.16"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="{StaticResource CardBorderHover}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="0" />
                        <ColorAnimation Duration="0:0:0.2"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="{StaticResource CardBorder}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- App Card Invalid Path Style -->
    <Style x:Key="AppCardInvalidStyle" TargetType="Border">
        <Setter Property="MinHeight" Value="128" />
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InvalidBorderBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="24" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.16"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="-1" />
                        <ColorAnimation Duration="0:0:0.16"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="{StaticResource Danger}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="0" />
                        <ColorAnimation Duration="0:0:0.2"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="{StaticResource InvalidBorder}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar Item Style (hover handled by ListBoxItem ControlTemplate) -->
    <Style x:Key="SidebarItemStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <!-- Premium App Icon Tile: 72x72, radius 18, elevated surface with border -->
    <Style x:Key="AppIconTileStyle" TargetType="Border">
        <Setter Property="Width" Value="72" />
        <Setter Property="Height" Value="72" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.14"
                                         Storyboard.TargetProperty="RenderTransform.ScaleX"
                                         To="1.03" />
                        <DoubleAnimation Duration="0:0:0.14"
                                         Storyboard.TargetProperty="RenderTransform.ScaleY"
                                         To="1.03" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Duration="0:0:0.18"
                                         Storyboard.TargetProperty="RenderTransform.ScaleX"
                                         To="1" />
                        <DoubleAnimation Duration="0:0:0.18"
                                         Storyboard.TargetProperty="RenderTransform.ScaleY"
                                         To="1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Empty state artwork container -->
    <Style x:Key="EmptyStateArtStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Background" Value="{StaticResource AccentSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentMutedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,0,0,36" />
    </Style>

</ResourceDictionary>
