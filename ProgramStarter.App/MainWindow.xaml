<Window x:Class="ProgramStarter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProgramStarter.App.ViewModels"
        Title="Kaldforge"
        Icon="pack://application:,,,/Assets/AppIcon/kaldforge.ico"
        MinWidth="920" MinHeight="620"
        Width="1080" Height="720"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- Inverted visibility: visible when HasGroups is false -->
        <Style x:Key="VisibleWhenNoGroups" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasGroups, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Visible when HasSelectedGroup is true -->
        <Style x:Key="VisibleWhenSelected" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Collapsed" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedGroup, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hidden when HasSelectedGroup is true (inverted) -->
        <Style x:Key="HiddenWhenSelected" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedGroup, Mode=OneWay}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Empty group state: visible only when selected group has no apps -->
        <Style x:Key="EmptyGroupStateVisibility" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelectedGroupEmpty, Mode=OneWay}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── No-Groups Empty State ── -->
        <DataTemplate x:Key="NoGroupsEmptyState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Asset: kaldforge_empty_slots_add.png — width 240, centered, preserve aspect ratio -->
                <Image Source="/Assets/Kaldforge/kaldforge_empty_slots_add.png"
                       Width="240"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,36" />

                <TextBlock Text="No groups yet"
                           Style="{StaticResource EmptyStateTitleStyle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Create your first launch group and start organizing your apps."
                           Style="{StaticResource EmptyStateTextStyle}"
                           Margin="0,0,0,28"
                           MaxWidth="380" />
                <Button Command="{Binding AddGroupCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="46"
                        MinWidth="150"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Add Group" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DataTemplate>

        <!-- ── Empty Group DataTemplate ── -->
        <DataTemplate x:Key="EmptyGroupState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Asset: kaldforge_empty_slots.png — width 240, centered, preserve aspect ratio -->
                <Image Source="/Assets/Kaldforge/kaldforge_empty_slots.png"
                       Width="240"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,0,36" />

                <TextBlock Text="No apps in this group yet"
                           Style="{StaticResource EmptyStateTitleStyle}"
                           Margin="0,0,0,8" />
                <TextBlock Text="Add your first app to build this launch group."
                           Style="{StaticResource EmptyStateTextStyle}"
                           Margin="0,0,0,28"
                           MaxWidth="380" />
                <Button Command="{Binding AddAppCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Height="46"
                        MinWidth="134"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Add App" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </DataTemplate>

        <!-- ── App Card Template ── -->
        <DataTemplate x:Key="AppCardTemplate" DataType="vm:AppEntryItemViewModel">
            <Border x:Name="AppCardBorder"
                    Margin="0,0,0,14"
                    Style="{StaticResource AppCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- App Icon Tile: 64x64, radius 16, image 44x44 -->
                    <!-- IconSource binds to real exe icon; falls back to Kaldforge if null -->
                    <Border Grid.Column="0"
                            Style="{StaticResource AppIconTileStyle}">
                        <Image Width="44" Height="44"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center">
                            <Image.Style>
                                <Style TargetType="Image">
                                    <Setter Property="Source" Value="{Binding IconSource, Mode=OneWay}" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IconSource, Mode=OneWay}" Value="{x:Null}">
                                            <Setter Property="Source" Value="/Assets/Kaldforge/kaldforge_icon_launch_tile.png" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Image.Style>
                        </Image>
                    </Border>

                    <!-- App info column -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,20,0">
                        <!-- App name — 18px SemiBold -->
                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,2" />

                        <!-- App path — 13px muted, one line ellipsis -->
                        <TextBlock Text="{Binding Path, Mode=OneWay}"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="NoWrap" />

                        <!-- Invalid path warning — icon + text below path -->
                        <StackPanel Orientation="Horizontal"
                                    Margin="0,4,0,0"
                                    Visibility="Collapsed">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPathValid, Mode=OneWay}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE7BA;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Path not found - edit to fix"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource WarningBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Actions: horizontal row, right aligned, vertically centered, gap 10 -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.LaunchAppCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource CompactPrimaryButtonStyle}"
                                    MinWidth="92">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Margin="0,0,6,0" />
                                    <TextBlock Text="Start" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.EditAppCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource NeutralButtonStyle}"
                                    MinWidth="84">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE70F;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Edit" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Button Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.RemoveAppCommand}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource DangerButtonStyle}"
                                    MinWidth="96">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="Remove" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="272" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════ Sidebar ═══════════════ -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid Margin="18,24,18,18">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Sidebar Brand Header — Height 86 -->
                <Grid Grid.Row="0" Height="86">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Kaldforge emblem tile: 64x64, radius 18, border 1 -->
                    <Border Grid.Column="0"
                            Width="80" Height="80"
                            CornerRadius="18"
                            Background="{StaticResource AccentSurfaceBrush}"
                            BorderBrush="{StaticResource AccentMutedBrush}"
                            BorderThickness="1"
                            Margin="0,0,14,0"
                            ToolTip="Kaldforge">
                        <Image Source="/Assets/Kaldforge/kaldforge_icon_launch_tile.png"
                               Width="75" Height="75"
                               Stretch="Uniform"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    </Border>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Kaldforge"
                                   Style="{StaticResource BrandTitleStyle}" />
                        <TextBlock Text="Program Starter"
                                   Style="{StaticResource BrandSubtitleStyle}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Sidebar divider: simple 1px line -->
                <Rectangle Grid.Row="1"
                           Height="1"
                           Fill="{StaticResource BorderBrush}"
                           Opacity="0.55"
                           Margin="0,18,0,16"
                           HorizontalAlignment="Stretch" />

                <!-- Section label -->
                <TextBlock Grid.Row="2"
                           Text="LAUNCH GROUPS"
                           Style="{StaticResource SidebarSectionLabelStyle}"
                           Margin="0,0,0,12" />

                <!-- Group List -->
                <ListBox Grid.Row="3"
                         ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SidebarItemStyle}">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource SidebarGroupNameStyle}" />
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Height" Value="56" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="14"
                                                Padding="12,0,12,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Left accent bar: simple 4x38 Rectangle -->
                                                <Rectangle Grid.Column="0"
                                                           x:Name="AccentBar"
                                                           Width="4"
                                                           Height="38"
                                                           RadiusX="2"
                                                           RadiusY="2"
                                                           Fill="{StaticResource AccentBrush}"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Left"
                                                           Opacity="0"
                                                           Margin="0,0,10,0" />

                                                <!-- Content -->
                                                <ContentPresenter Grid.Column="1" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Duration="0:0:0.13"
                                                                        Storyboard.TargetName="ItemBorder"
                                                                        Storyboard.TargetProperty="Background.Color"
                                                                        To="{StaticResource SidebarHover}" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <ColorAnimation Duration="0:0:0.15"
                                                                        Storyboard.TargetName="ItemBorder"
                                                                        Storyboard.TargetProperty="Background.Color"
                                                                        To="Transparent" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                                                <Setter TargetName="AccentBar" Property="Opacity" Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Add Group button -->
                <Button Grid.Row="4"
                        Command="{Binding AddGroupCommand}"
                        Style="{StaticResource SidebarAddGroupButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <TextBlock Text="Add Group" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- ═══════════════ Main Content Area ═══════════════ -->
        <Grid Grid.Column="1" Margin="40,36,40,28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- No-Groups Empty State -->
            <ContentControl Grid.Row="0" Grid.RowSpan="3"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NoGroupsEmptyState}"
                            Style="{StaticResource VisibleWhenNoGroups}" />

            <!-- Content shown when groups exist -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding HasGroups, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">

                <!-- Header when a group is selected -->
                <StackPanel Style="{StaticResource VisibleWhenSelected}">
                    <Grid Height="84">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedGroup.Name, Mode=OneWay, FallbackValue='Select a group'}"
                                       FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Margin="0,4,0,0"
                                       FontSize="13"
                                       Foreground="{StaticResource TextMutedBrush}">
                                <Run Text="{Binding SelectedGroupAppCount, Mode=OneWay}" />
                                <Run Text=" app in this group" />
                            </TextBlock>
                        </StackPanel>

                        <!-- Header action buttons: 10px gap between all buttons -->
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,10,0">
                            <!-- Rename Group icon button -->
                            <Button ToolTip="Rename Group"
                                    Command="{Binding RenameGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}"
                                    Style="{StaticResource HeaderIconButtonStyle}"
                                    Margin="0,0,10,0">
                                <TextBlock Text="&#xE70F;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                            <!-- Delete Group icon button -->
                            <Button ToolTip="Delete Group"
                                    Command="{Binding DeleteGroupCommand}"
                                    CommandParameter="{Binding SelectedGroup}"
                                    Style="{StaticResource HeaderDangerIconButtonStyle}">
                                <TextBlock Text="&#xE74D;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="15"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Button>
                        </StackPanel>

                        <!-- Start Group button -->
                        <Button Grid.Column="2"
                                Command="{Binding LaunchGroupCommand}"
                                Margin="0,0,10,0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                    <Setter Property="Content" Value="▶ Start Group" />
                                    <Setter Property="IsEnabled" Value="True" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLaunching, Mode=OneWay}" Value="True">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding HasSelectedGroup, Mode=OneWay}" Value="False">
                                            <Setter Property="IsEnabled" Value="False" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- Add App button -->
                        <Button Grid.Column="3"
                                Command="{Binding AddAppCommand}"
                                Style="{StaticResource SecondaryButtonStyle}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0" />
                                <TextBlock Text="Add App" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Header divider: full width 1px line -->
                    <Rectangle Height="1"
                               Fill="{StaticResource BorderBrush}"
                               Opacity="0.55"
                               Margin="0,18,0,24"
                               HorizontalAlignment="Stretch" />

                    <!-- Amber divider asset directly under the line -->
                    <Image Source="/Assets/Kaldforge/kaldforge_divider_crystal_amber.png"
                           Width="260"
                           Height="8"
                           Stretch="UniformToFill"
                           Opacity="0.45"
                           Margin="0,-28,0,0"
                           HorizontalAlignment="Left" />
                </StackPanel>

                <!-- When groups exist but none is selected -->
                <Border Style="{StaticResource HiddenWhenSelected}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                Margin="0,100,0,0">
                        <TextBlock Text="Select a group to get started"
                                   Style="{StaticResource EmptyStateTitleStyle}"
                                   Margin="0,0,0,8" />
                        <TextBlock Text="Choose a launch group from the sidebar to manage its apps."
                                   Style="{StaticResource EmptyStateTextStyle}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Main Inner Surface Panel for App List -->
            <Border Grid.Row="1"
                    Margin="0,0,0,0"
                    Visibility="{Binding HasSelectedGroup, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}"
                    CornerRadius="28"
                    BorderThickness="1"
                    Padding="24,8,24,8"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Background="{StaticResource SurfaceElevatedBrush}"
                    BorderBrush="{StaticResource CardBorderBrush}"
                    ClipToBounds="False">
                <Grid ClipToBounds="False">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ClipToBounds="False">
                        <ItemsControl ItemsSource="{Binding SelectedGroupApps, Mode=OneWay}"
                                      ClipToBounds="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ContentPresenter Content="{Binding}" ContentTemplate="{StaticResource AppCardTemplate}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty group state -->
                    <ContentControl Content="{Binding}"
                                    ContentTemplate="{StaticResource EmptyGroupState}"
                                    Style="{StaticResource EmptyGroupStateVisibility}" />
                </Grid>
            </Border>

            <!-- Status message area -->
            <Grid Grid.Row="2"
                  Height="24"
                  Margin="0,4,0,0"
                  Visibility="{Binding HasSelectedGroup, Mode=OneWay, Converter={StaticResource BoolToVisConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status text only - no icon -->
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage, Mode=OneWay, FallbackValue='Ready'}"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />

                <TextBlock Grid.Column="2"
                           Text="Kaldforge v1"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"
                           Opacity="0.5"
                           VerticalAlignment="Center" />
            </Grid>
        </Grid>
    </Grid>
</Window>
