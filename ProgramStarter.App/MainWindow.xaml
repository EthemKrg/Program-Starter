<Window x:Class="ProgramStarter.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Program Starter"
        MinWidth="900" MinHeight="560"
        Width="960" Height="640"
        Background="{StaticResource BackgroundBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        WindowStartupLocation="CenterScreen"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter" />

        <!-- Inverted BooleanToVisibilityConverter via style trigger -->
        <Style x:Key="VisibleWhenFalse" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasGroups}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Hidden when HasSelectedGroup is true (inverted) -->
        <Style x:Key="HiddenWhenSelected" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasSelectedGroup}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- No-Groups Empty State -->
        <DataTemplate x:Key="NoGroupsEmptyState">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <!-- Placeholder star icon -->
                <Viewbox Width="48" Height="48" Margin="0,0,0,16">
                    <Canvas Width="24" Height="24">
                        <Path Data="M12,2 L14,8 L20,8 L15,12 L17,18 L12,14 L7,18 L9,12 L4,8 L10,8 Z"
                              Fill="{StaticResource TextMutedBrush}" />
                    </Canvas>
                </Viewbox>
                <TextBlock Text="No groups yet."
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,0,0,8" />
                <TextBlock Text="Create your first launch group."
                           Style="{StaticResource EmptyStateTextStyle}"
                           Margin="0,0,0,20" />
                <Button Content="+ Add Group"
                        Command="{Binding AddGroupCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid Margin="0,28,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Sidebar Header -->
                <TextBlock Grid.Row="0"
                           Text="Groups"
                           Style="{StaticResource SectionTitleStyle}"
                           Margin="16,0,16,16" />

                <!-- Group List -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Groups}"
                         SelectedItem="{Binding SelectedGroup}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="8,0,8,0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SidebarItemStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Style="{StaticResource BodyTextStyle}"
                                               TextTrimming="CharacterEllipsis"
                                               VerticalAlignment="Center" />

                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Margin="4,0,0,0">
                                        <Button Content="✏"
                                                ToolTip="Rename"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.RenameGroupCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Width="24" Height="24"
                                                Padding="0"
                                                FontSize="11" />
                                        <Button Content="✕"
                                                ToolTip="Delete"
                                                Command="{Binding RelativeSource={RelativeSource AncestorType={x:Type Window}}, Path=DataContext.DeleteGroupCommand}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource GhostButtonStyle}"
                                                Width="24" Height="24"
                                                Padding="0"
                                                Margin="2,0,0,0"
                                                FontSize="11"
                                                Foreground="{StaticResource DangerBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Margin" Value="0,2" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="ItemBorder"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                Padding="12,8">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource CardHoverBrush}" />
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SelectedSurfaceBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Add Group Button -->
                <Button Grid.Row="2"
                        Content="+ Add Group"
                        Command="{Binding AddGroupCommand}"
                        Style="{StaticResource GhostButtonStyle}"
                        Margin="8,8,8,16" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Margin="28,28,28,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- No-Groups Empty State (visible when HasGroups is false) -->
            <ContentControl Grid.Row="0" Grid.RowSpan="3"
                            Content="{Binding}"
                            ContentTemplate="{StaticResource NoGroupsEmptyState}"
                            Style="{StaticResource VisibleWhenFalse}" />

            <!-- Content shown when groups exist -->
            <StackPanel Grid.Row="0"
                        Visibility="{Binding HasGroups, Converter={StaticResource BoolToVisConverter}}">

                <!-- When a group is selected: show group name and app count -->
                <StackPanel Visibility="{Binding HasSelectedGroup, Converter={StaticResource BoolToVisConverter}}">
                    <TextBlock Text="{Binding SelectedGroup.Name, FallbackValue='Select a group'}"
                               Style="{StaticResource MainTitleStyle}" />
                    <TextBlock Margin="0,4,0,0"
                               Style="{StaticResource SecondaryTextStyle}">
                        <Run Text="{Binding SelectedGroup.Apps.Count}" />
                        <Run Text=" apps" />
                    </TextBlock>
                </StackPanel>

                <!-- When groups exist but none is selected: prompt to select -->
                <Border Style="{StaticResource HiddenWhenSelected}">
                    <TextBlock Text="Select a group to manage apps"
                               Style="{StaticResource SectionTitleStyle}"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Status Bar -->
            <Border Grid.Row="2"
                    Height="32"
                    Background="{StaticResource SurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8">
                <TextBlock Text="{Binding StatusMessage, FallbackValue='Ready'}"
                           Style="{StaticResource MutedTextStyle}"
                           VerticalAlignment="Center"
                           Margin="12,0" />
            </Border>
        </Grid>
    </Grid>
</Window>
