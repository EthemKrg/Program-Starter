                                                     To="1" />
                                    <DoubleAnimation Duration="0:0:0.15"
                                                     Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                     To="1" />
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsEnabled" Value="False">
