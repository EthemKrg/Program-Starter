<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════════════
         Kaldforge Color Palette — Phase 5C
         Theme: Dark forge, metallic stone/steel, muted blue crystal,
         subtle amber glow. Premium, memorable WPF dark theme.
         ════════════════════════════════════════════════════════════════ -->

    <!-- ── Foundation: Dark Forge ── -->
    <!-- Background: deep forge pit #0A0E14 -->
    <Color x:Key="Background">#0A0E14</Color>
    <!-- Sidebar: darker stone #0F131A -->
    <Color x:Key="Sidebar">#0F131A</Color>
    <!-- Surface: forged steel plate #131820 -->
    <Color x:Key="Surface">#131820</Color>
    <!-- Elevated surface: lighter steel highlight #18202A -->
    <Color x:Key="SurfaceElevated">#18202A</Color>

    <!-- ── Cards: Metallic Stone/Steel ── -->
    <Color x:Key="Card">#131820</Color>
    <Color x:Key="CardHover">#1A2330</Color>
    <Color x:Key="CardBorder">#1E2A38</Color>
    <Color x:Key="CardBorderHover">#3A4E64</Color>
    <Color x:Key="SelectedSurface">#1A2640</Color>
    <Color x:Key="SidebarSelected">#141E35</Color>
    <Color x:Key="SidebarHover">#19202E</Color>

    <!-- ── Accent: Muted Blue Crystal ── -->
    <!-- Primary crystal glow #6B7FFF -->
    <Color x:Key="Accent">#6B7FFF</Color>
    <Color x:Key="AccentHover">#7F91FF</Color>
    <Color x:Key="AccentPressed">#5A6DE6</Color>
    <Color x:Key="AccentMuted">#252E50</Color>
    <Color x:Key="AccentGlow">#181E40</Color>
    <Color x:Key="AccentSurface">#10162E</Color>

    <!-- ── Amber Accent: Subtle Forge Glow ── -->
    <Color x:Key="Amber">#D4A043</Color>
    <Color x:Key="AmberGlow">#3A2E18</Color>
    <Color x:Key="AmberMuted">#5A4A20</Color>

    <!-- ── Text: Metallic Steel ── -->
    <Color x:Key="TextPrimary">#E2E6EC</Color>
    <Color x:Key="TextSecondary">#8892A0</Color>
    <Color x:Key="TextMuted">#5A6476</Color>

    <!-- ── Semantic Colors ── -->
    <Color x:Key="Danger">#E04848</Color>
    <Color x:Key="DangerHover">#F06060</Color>
    <Color x:Key="DangerPressed">#C03030</Color>
    <Color x:Key="DangerSurface">#1C1015</Color>
    <Color x:Key="Success">#34D399</Color>
    <Color x:Key="Warning">#D4A043</Color>
    <Color x:Key="Border">#263040</Color>
    <Color x:Key="BorderMuted">#1A2230</Color>
    <Color x:Key="InvalidBorder">#6B1A1A</Color>

    <!-- ════════════════════════════════════════
         Brush Resources
         ════════════════════════════════════════ -->

    <!-- Foundation -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="SidebarBrush" Color="{StaticResource Sidebar}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="{StaticResource SurfaceElevated}" />

    <!-- Cards -->
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource Card}" />
    <SolidColorBrush x:Key="CardHoverBrush" Color="{StaticResource CardHover}" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorder}" />
    <SolidColorBrush x:Key="CardBorderHoverBrush" Color="{StaticResource CardBorderHover}" />
    <SolidColorBrush x:Key="SelectedSurfaceBrush" Color="{StaticResource SelectedSurface}" />

    <!-- Crystal Accent -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressed}" />
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}" />
    <SolidColorBrush x:Key="AccentGlowBrush" Color="{StaticResource AccentGlow}" />
    <SolidColorBrush x:Key="AccentSurfaceBrush" Color="{StaticResource AccentSurface}" />

    <!-- Amber Accent -->
    <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource Amber}" />
    <SolidColorBrush x:Key="AmberGlowBrush" Color="{StaticResource AmberGlow}" />
    <SolidColorBrush x:Key="AmberMutedBrush" Color="{StaticResource AmberMuted}" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}" />

    <!-- Semantic -->
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="{StaticResource DangerHover}" />
    <SolidColorBrush x:Key="DangerPressedBrush" Color="{StaticResource DangerPressed}" />
    <SolidColorBrush x:Key="DangerSurfaceBrush" Color="{StaticResource DangerSurface}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BorderMutedBrush" Color="{StaticResource BorderMuted}" />
    <SolidColorBrush x:Key="InvalidBorderBrush" Color="{StaticResource InvalidBorder}" />
    <SolidColorBrush x:Key="SidebarSelectedBrush" Color="{StaticResource SidebarSelected}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHover}" />

</ResourceDictionary>
