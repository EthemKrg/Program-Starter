<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- App Card Style with subtle hover lift -->
    <Style x:Key="AppCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Duration="0:0:0.15"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="{StaticResource CardHover}" />
                        <ColorAnimation Duration="0:0:0.15"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="{StaticResource Border}" />
                        <DoubleAnimation Duration="0:0:0.15"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="-1" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Duration="0:0:0.2"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="{StaticResource Card}" />
                        <ColorAnimation Duration="0:0:0.2"
                                        Storyboard.TargetProperty="BorderBrush.Color"
                                        To="Transparent" />
                        <DoubleAnimation Duration="0:0:0.2"
                                         Storyboard.TargetProperty="RenderTransform.Y"
                                         To="0" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- App Card Invalid Path Style -->
    <Style x:Key="AppCardInvalidStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource InvalidBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform X="0" Y="0" />
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Duration="0:0:0.15"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="{StaticResource CardHover}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <ColorAnimation Duration="0:0:0.2"
                                        Storyboard.TargetProperty="Background.Color"
                                        To="{StaticResource Card}" />
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- Sidebar Item Style -->
    <Style x:Key="SidebarItemStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

</ResourceDictionary>
