<Window x:Class="ProgramStarter.App.Views.Dialogs.AppEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="DialogRoot"
        Title="Edit App"
        MinWidth="480" MaxWidth="560"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="ToolWindow"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="{StaticResource DefaultFontFamily}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="DialogTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="MinHeight" Value="32" />
        </Style>
        <Style x:Key="ValidationMessageStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="Margin" Value="0,4,0,0" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="20">
        <TextBlock Text="Edit App" Style="{StaticResource DialogTitleStyle}" />

        <!-- Name -->
        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}" />
        <TextBox x:Name="NameTextBox"
                 Text="{Binding AppName, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource DialogTextBoxStyle}"
                 Margin="0,0,0,4"
                 KeyDown="OnNameKeyDown" />

        <!-- Path -->
        <TextBlock Text="Path" Style="{StaticResource FieldLabelStyle}" Margin="0,12,0,4" />
        <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     x:Name="PathTextBox"
                     Text="{Binding AppPath, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource DialogTextBoxStyle}"
                     IsReadOnly="False"
                     KeyDown="OnPathKeyDown" />
            <Button Grid.Column="1"
                    Content="Browse"
                    Style="{StaticResource NeutralButtonStyle}"
                    Margin="8,0,0,0"
                    Padding="12,6"
                    Click="OnBrowseClick" />
        </Grid>

        <!-- Buttons -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Cancel"
                    Style="{StaticResource NeutralButtonStyle}"
                    IsCancel="True"
                    Margin="0,0,8,0" />
            <Button x:Name="OkButton"
                    Content="OK"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsDefault="True"
                    Click="OnOkClick" />
        </StackPanel>
    </StackPanel>
</Window>
